# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Auth
AUTH_SECRET=change-me-to-a-random-string

# Session settings
SESSION_TTL_HOURS=4
MAX_SESSIONS=100

# Email (SMTP) — required for facilitator PIN auth
# For AWS SES:
#   SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#   SMTP_PORT=587
# For local development, use a service like Mailtrap or Ethereal
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
